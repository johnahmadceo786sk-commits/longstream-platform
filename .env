# ==============================
# APPLICATION
# ==============================

APP_NAME=LongStream Platform
APP_ENV=development
APP_PORT=8000

# ==============================
# DATABASE
# ==============================

POSTGRES_DB=longstream_db
POSTGRES_USER=longstream_user
POSTGRES_PASSWORD=longstream_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://longstream_user:longstream_password@db:5432/longstream_db

# ==============================
# REDIS
# ==============================

REDIS_HOST=redis
REDIS_PORT=6379

# ==============================
# SECURITY
# ==============================

JWT_SECRET=SUPER_SECRET_JWT_KEY_CHANGE_THIS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Default Host
DEFAULT_HOST_USERNAME=john
DEFAULT_HOST_PASSWORD=CEOjohn$$

# ==============================
# STORAGE
# ==============================

STORAGE_PATH=/app/storage

# ==============================
# CELERY
# ==============================

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0